# AEGIS-FOOD Production Environment Variables Template
# Copy to .env and fill in with your actual values
# NEVER commit the actual .env file with real secrets to version control

# ========================================
# APPLICATION SETTINGS
# ========================================

# Environment mode (production, staging, development)
ENVIRONMENT=production

# Secret key for JWT token signing - generate with: openssl rand -base64 32
# Change this to a strong random value!
SECRET_KEY=your-secret-key-change-this-to-random-value

# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info

# Flask/FastAPI debug mode (always false in production)
DEBUG=false

# ========================================
# DATABASE CONFIGURATION
# ========================================

# PostgreSQL with PostGIS
# Format: postgresql://username:password@host:port/database
# If using managed database service, copy the full connection string
DB_USER=postgres
DB_PASSWORD=your-secure-db-password-here
DB_NAME=aegis_food_prod
DB_HOST=db
DB_PORT=5432

# Full DATABASE_URL (alternative to individual DB_* variables)
# DATABASE_URL=postgresql://postgres:password@db:5432/aegis_food_prod

# Database connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600

# ========================================
# REDIS CACHE & QUEUE CONFIGURATION
# ========================================

# Redis connection string
# Format: redis://:password@host:port/db
# For Redis Cloud: redis://:password@host.redis.cloud:port/0
REDIS_URL=redis://:your-redis-password@redis:6379/0
REDIS_PASSWORD=your-redis-password

# Redis settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_KEEPALIVE=true
REDIS_SOCKET_KEEPALIVE_INTERVAL=30

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================

# Enable/disable email notifications
NOTIFICATIONS_ENABLED=true

# SMTP Server Configuration
# Gmail example uses App Password, not regular password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Sender email address
SMTP_FROM_EMAIL=noreply@aegis-food.com
SMTP_FROM_NAME=AEGIS-FOOD Marketplace

# TLS settings
SMTP_TLS=true
SMTP_SSL=false

# ========================================
# JWT TOKEN CONFIGURATION
# ========================================

# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# Refresh token expiration (optional, in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# GUNICORN WORKERS
# ========================================

# Number of worker processes
# Formula: (2 × CPU cores) + 1
# For 2 CPU: 5 workers, for 4 CPU: 9 workers
WORKERS=5

# Timeout for worker process in seconds
WORKER_TIMEOUT=120

# ========================================
# CORS CONFIGURATION
# ========================================

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://aegis-food.com,https://www.aegis-food.com,https://app.aegis-food.com

# Allow credentials in CORS requests
ALLOW_CREDENTIALS=true

# ========================================
# DOMAIN & URL CONFIGURATION
# ========================================

# Application domain
APP_DOMAIN=aegis-food.com

# Application URLs
API_URL=https://api.aegis-food.com
FRONTEND_URL=https://aegis-food.com

# ========================================
# SECURITY CONFIGURATION
# ========================================

# HTTPS enforcement
FORCE_HTTPS=true

# HSTS max age in seconds
HSTS_MAX_AGE=31536000

# Enable rate limiting
ENABLE_RATE_LIMIT=true

# Rate limit requests per minute
RATE_LIMIT_REQUESTS=100

# ========================================
# MONITORING & OBSERVABILITY
# ========================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable request/response logging
LOG_REQUESTS=false

# Log slow queries (milliseconds)
SLOW_QUERY_LOG_MS=1000

# ========================================
# FEATURE FLAGS
# ========================================

# Enable carbon footprint calculation
ENABLE_CARBON_FOOTPRINT=true

# Enable matching algorithm
ENABLE_MATCHING=true

# Enable compliance checks
ENABLE_COMPLIANCE=true

# ========================================
# THIRD-PARTY SERVICES (Optional)
# ========================================

# AWS S3 for file uploads (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-west-1

# Stripe for payments (optional)
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=

# Google Maps API (optional)
GOOGLE_MAPS_API_KEY=

# ========================================
# DEPLOYMENT-SPECIFIC
# ========================================

# Deployment platform (docker, railway, fly, kubernetes)
DEPLOYMENT_PLATFORM=docker

# Container port (usually 8000 for FastAPI)
PORT=8000

# ========================================
# NOTES FOR PRODUCTION SETUP
# ========================================

# 1. DATABASE PASSWORD:
#    - Generate strong password: openssl rand -base64 32
#    - Use managed database service (AWS RDS, Google Cloud SQL, etc.)
#    - Enable automated backups and point-in-time recovery
#    - Enable encryption at rest and in transit
#    - Restrict network access to application only

# 2. REDIS PASSWORD:
#    - Use Redis Cloud or managed service
#    - Generate strong password: openssl rand -base64 32
#    - Enable TLS encryption
#    - Set up automatic backups

# 3. SECRET_KEY:
#    - Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    - Store securely in secret management system
#    - Rotate periodically (monthly recommended)

# 4. SMTP CONFIGURATION:
#    - For Gmail: Enable 2FA, generate App Password
#    - Consider transactional email service (SendGrid, Mailgun, AWS SES)
#    - Set up bounce/complaint handling

# 5. SSL/TLS CERTIFICATES:
#    - Use Let's Encrypt (free) or commercial provider
#    - Deploy certificates in /deploy/ssl/ directory
#    - Set up auto-renewal

# 6. ENVIRONMENT VARIABLES:
#    - Never commit .env file to version control
#    - Use secret management: AWS Secrets Manager, Google Secret Manager
#    - On Railway: Use Railway dashboard to set secrets
#    - On Fly.io: Use `flyctl secrets set KEY=value`
#    - On Kubernetes: Use Secrets resource or external secrets operator

# 7. DATABASE INITIALIZATION:
#    - Run migrations on first deploy
#    - Backup database before migrations
#    - Test rollback procedure

# 8. MONITORING:
#    - Set up uptime monitoring
#    - Enable application logging to centralized service
#    - Set up alerts for errors and performance issues
#    - Monitor resource usage (CPU, memory, disk)

# ========================================
# TROUBLESHOOTING
# ========================================

# If deployment fails:
# 1. Check logs: docker logs aegis-food-backend-prod
# 2. Verify database connectivity: psql $DATABASE_URL
# 3. Verify Redis connectivity: redis-cli -u $REDIS_URL ping
# 4. Check SMTP settings: telnet $SMTP_SERVER $SMTP_PORT
# 5. Verify environment variables are set correctly

# Common issues:
# - "connection refused" → check service health and network
# - "permission denied" → check file permissions and user privileges
# - "out of memory" → increase container memory limit
# - "rate limited" → check SMTP provider limits
